# Cron job example để chạy tự động
# Thêm vào crontab bằng: crontab -e

# Chạy mỗi 6 giờ (vào lúc 00:00, 06:00, 12:00, 18:00)
0 */6 * * * cd /path/to/agri-scraper && /bin/bash run.sh >> logs/cron.log 2>&1

# Chạy mỗi ngày lúc 8:00 sáng
0 8 * * * cd /path/to/agri-scraper && /bin/bash run.sh >> logs/cron.log 2>&1

# Chạy mỗi 3 giờ
0 */3 * * * cd /path/to/agri-scraper && /bin/bash run.sh >> logs/cron.log 2>&1

# Lưu ý:
# - Thay /path/to/agri-scraper bằng đường dẫn thực tế
# - Tạo thư mục logs trước: mkdir -p logs
# - Đảm bảo file .env có trong thư mục
